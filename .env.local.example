# Copy this file to .env.local and fill in the values from your Supabase
# project (Project Settings → API). .env.local is gitignored.
#
# The anon key is safe to ship to the browser because Row Level Security
# (RLS) enforces per-user access on every table. The service_role key is
# NOT safe and must never live in this file.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# M23 — server-only Supabase key for the /admin dashboard. Bypasses RLS to
# aggregate event/user data across all rows. NEVER expose to the browser
# (no NEXT_PUBLIC_ prefix). Required for /api/admin/metrics to function;
# the rest of the app works without it.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
